{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mestia",
  "version": "0.1.0",
  "identifier": "com.mestia.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mestia",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Mestia",
    "copyright": "© Mestia",
    "category": "Utility",
    "shortDescription": "Загрузчик видео и медиатека",
    "longDescription": "Mestia — кроссплатформенный загрузчик видео/аудио с медиатекой и плеером.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg", "binaries/ffprobe"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["Russian", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
